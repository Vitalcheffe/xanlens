# XanLens — Environment Variables
# Copy this to .env.local and fill in your keys

# === REQUIRED: Core engine ===
GEMINI_API_KEY=           # Google Gemini — REQUIRED. Powers knowledge + grounded search + LLM judge. Free key at ai.google.dev

# === OPTIONAL: Additional engines (add for full multi-engine audit) ===
OPENAI_API_KEY=           # ChatGPT queries
ANTHROPIC_API_KEY=        # Claude queries
XAI_API_KEY=              # Grok queries
DEEPSEEK_API_KEY=         # DeepSeek queries
PERPLEXITY_API_KEY=       # Perplexity queries

# === REQUIRED: Database ===
TURSO_DATABASE_URL=       # Turso/LibSQL database URL
TURSO_AUTH_TOKEN=         # Turso auth token

# === REQUIRED: Cache ===
KV_REST_API_URL=          # Upstash Redis URL
KV_REST_API_TOKEN=        # Upstash Redis token

# === RECOMMENDED: Full audit quality ===
TAVILY_API_KEY=           # Tavily search — strongly recommended, powers citation analysis and content scoring
GEMINI_JUDGE_KEY=         # Separate Gemini key for LLM judge (brand verification)
GOOGLE_API_KEY=           # Google Search API (for SEO score)

# === OPTIONAL: Enhanced features ===
DATAFORSEO_AUTH=          # DataForSEO (advanced SEO metrics)
EXA_API_KEY=              # Exa search (content discovery)

# === OPTIONAL: Payments (Coinbase) ===
CDP_API_KEY=
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_API_SECRET=
CDP_PAYMASTER_URL=
BASE_RPC_URL=

# === OPTIONAL: Other ===
ADMIN_SECRET=             # Admin endpoints auth
BLOG_ADMIN_SECRET=        # Blog management auth
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Mistral (optional)
MISTRAL_API_KEY=
